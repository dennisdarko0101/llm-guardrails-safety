# LLM Guardrails Safety — Environment Configuration
# Copy this file to .env and fill in your values

# API Keys (required for LLM-based detection modes)
GUARDRAILS_ANTHROPIC_API_KEY=
GUARDRAILS_OPENAI_API_KEY=

# Safety Configuration
GUARDRAILS_SAFETY_LEVEL=moderate          # strict, moderate, permissive
GUARDRAILS_MAX_INPUT_LENGTH=10000
GUARDRAILS_ENABLE_PII_REDACTION=true
GUARDRAILS_TOXICITY_THRESHOLD=0.7
GUARDRAILS_INJECTION_SENSITIVITY=medium   # low, medium, high

# LLM-Based Detection (more accurate, requires API keys)
GUARDRAILS_ENABLE_LLM_DETECTION=false
GUARDRAILS_LLM_PROVIDER=anthropic         # anthropic, openai
GUARDRAILS_LLM_MODEL=claude-sonnet-4-20250514

# Server
GUARDRAILS_HOST=0.0.0.0
GUARDRAILS_PORT=8000

# Logging
GUARDRAILS_LOG_LEVEL=INFO
GUARDRAILS_LOG_JSON=true

# Feature Flags
GUARDRAILS_ENABLE_TOPIC_BOUNDARY=true
GUARDRAILS_ENABLE_HALLUCINATION_DETECTION=false
GUARDRAILS_ENABLE_OUTPUT_VALIDATION=true
